# Logi Composer MCP Server Configuration
# Copy this file to .env and fill in your values.

# Required: Composer login credentials (Basic auth)
COMPOSER_USERNAME=admin
COMPOSER_PASSWORD=password

# Required: Composer server hostname (no trailing slash, no path)
COMPOSER_HOST=http://localhost:8008

# Required: Base path — use /discovery for cloud/UAT, /composer for local installs
COMPOSER_BASE_PATH=/composer

# Optional: Verify SSL certificates (set to false for self-signed certs or local HTTP)
COMPOSER_VERIFY_SSL=false

# Optional: Request timeout in seconds
COMPOSER_TIMEOUT=30
